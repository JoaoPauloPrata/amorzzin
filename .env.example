# Supabase (public — exposed to browser)
# Use modern publishable key (sb_publishable_...) for new apps. Legacy anon JWT also works.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Service role: usado por Server Actions Next (mutations) e Edge Functions.
# - Local dev: cole aqui. Nunca commitar.
# - Vercel: setar em Project Settings > Environment Variables (todas as envs).
# - Edge Functions (Supabase): setar via `supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...`.
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MercadoPago
# MP_ACCESS_TOKEN: usado pela Server Action createPaymentPreference (Vercel) E pela Edge mp-webhook.
#   - Local dev: cole aqui (token de TESTE — começa com TEST-...).
#   - Vercel: setar em env vars (Production usa token de PROD; Preview/Dev usam TEST-).
#   - Edge: `supabase secrets set MP_ACCESS_TOKEN=...`
# MP_WEBHOOK_SECRET: chave secreta gerada no painel MP > Webhooks > Configurar notificações.
#   - Apenas na Edge: `supabase secrets set MP_WEBHOOK_SECRET=...`. NÃO precisa no Vercel.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Email (Edge Functions only)
RESEND_API_KEY=
RESEND_FROM="Amorzzin <no-reply@amorzzin.com>"
